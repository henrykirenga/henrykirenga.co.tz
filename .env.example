# Server-side scripts only (scripts/*.mjs). NEVER ship these to the browser.
# Copy to `.env` and fill in from Supabase → Project Settings → API.

SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# The service_role key BYPASSES Row Level Security. Keep it secret.
# Used only by the local import / admin-creation scripts.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Used by `npm run create-admin` to create your first admin login.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=choose-a-strong-password
